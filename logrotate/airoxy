/var/log/airoxy/*.log {
    monthly
    rotate 3
    compress
    delaycompress
    missingok
    notifempty
    dateext
    dateformat -%Y%m
    create 0644 www-data www-data
}

/var/www/airoxy/storage/logs/*.log {
    monthly
    rotate 3
    compress
    delaycompress
    missingok
    notifempty
    dateext
    dateformat -%Y%m
    create 0644 www-data www-data
}
